{
  "name": "@world-forge/export-ai-rpg",
  "version": "4.4.2",
  "description": "Export/import pipeline between WorldProject and ai-rpg-engine ContentPack",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "bin": {
    "world-forge-export": "dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md",
    "LICENSE",
    "logo.png"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "mcp-tool-shop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/world-forge.git",
    "directory": "packages/export-ai-rpg"
  },
  "homepage": "https://mcp-tool-shop-org.github.io/world-forge/",
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/world-forge/issues"
  },
  "keywords": [
    "world-forge",
    "export",
    "ai-rpg-engine",
    "content-pack",
    "rpg",
    "typescript"
  ],
  "//": "ai-rpg-engine/* deps: see src/ENGINE_CONTRACT.md for the 2.x API shape this exporter depends on and the checklist for a future 3.x bump.",
  "dependencies": {
    "@world-forge/schema": "*",
    "@ai-rpg-engine/content-schema": "^2.0.1",
    "@ai-rpg-engine/core": "^2.0.1",
    "@ai-rpg-engine/modules": "^2.1.0",
    "@ai-rpg-engine/pack-registry": "^2.0.2",
    "@ai-rpg-engine/character-creation": "^2.0.2",
    "@ai-rpg-engine/equipment": "^2.0.2"
  }
}

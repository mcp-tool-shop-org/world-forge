{
  "name": "@world-forge/export-unreal",
  "version": "4.4.2",
  "description": "Export pipeline between WorldProject and an Unreal Engine 5 ContentPack (2.5D aware).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "bin": {
    "world-forge-export-unreal": "dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "author": "mcp-tool-shop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/world-forge.git",
    "directory": "packages/export-unreal"
  },
  "homepage": "https://mcp-tool-shop-org.github.io/world-forge/",
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/world-forge/issues"
  },
  "keywords": [
    "world-forge",
    "export",
    "unreal-engine",
    "ue5",
    "2.5d",
    "rpg",
    "typescript"
  ],
  "dependencies": {
    "@world-forge/schema": "*"
  }
}

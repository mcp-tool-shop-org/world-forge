{
  "name": "world-forge",
  "version": "4.4.0",
  "private": true,
  "description": "2D/2.5D world authoring studio with peer export lanes for AI RPG Engine, Unreal Engine 5, and Godot 4.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "sync-version": "node scripts/sync-version.mjs",
    "verify": "npm run build && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/world-forge.git"
  },
  "homepage": "https://mcp-tool-shop-org.github.io/world-forge/",
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/world-forge/issues"
  },
  "author": "mcp-tool-shop",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
